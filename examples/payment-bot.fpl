# Faramesh Policy Language — payment agent governance
# This policy governs a payment-processing AI agent.

agent payment-bot {
  default deny
  model "gpt-4o"
  framework "langgraph"

  budget session {
    max $500
    daily $2000
    max_calls 100
    on_exceed deny
  }

  phase intake {
    permit read_customer
    permit get_order
  }

  phase execution {
    permit stripe/refund
    permit send_notification
  }

  rules {
    deny! shell/* reason: "never shell"

    defer stripe/refund when amount > 500
      notify: "finance"
      reason: "high value refund"

    permit stripe/* when amount <= 500

    deny read_customer
      when not purpose("refund_processing")
      reason: "purpose required"

    deny stripe/refund
      when history_tool_count("stripe/refund") > 20
      reason: "refund call volume limit exceeded"
  }

  credential stripe {
    scope refund read_charge
    max_scope "refund:amount<=1000"
  }
}
