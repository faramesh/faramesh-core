agent default {
  default deny

  budget session {
    max_calls 500
    daily $10
    on_exceed deny
  }

  rules {
    permit http/get
    defer shell/* reason: "shell commands require human approval"
    defer stripe/refund when amount > 500
      reason: "refund over $500 requires human approval"
    permit stripe/refund when amount <= 500
  }
}
