agent default {
  default deny

  budget session {
    max_calls 500
    daily $10
    on_exceed deny
  }

  rules {
    permit http/get

    # Keep existing high-risk operations in human approval flow.
    defer shell/* reason: "shell commands require human approval"
    defer stripe/refund
      reason: "refund requires human approval"

    # Stage 10: narrow proxy allowlist for first enforce slice.
    permit proxy/connect port: 443
    permit proxy/http host: api.openai.com port: 443 method: POST path: /v1/chat/completions
    permit proxy/http host: api.openai.com port: 443 method: POST path: /v1/responses
  }
}
