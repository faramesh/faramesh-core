# Optional FPL sidecar; URL and path tiering live in YAML.
agent p2-docs-writer {
  default deny

  rules {
    deny! shell/*
      reason: "doc agents must not invoke shell"

    defer file/write/*
      notify: "docs-owners"
      reason: "publishing requires approval"

    permit search/*
    permit file/read/*
    permit http/get
      reason: "internal doc hosts enforced in YAML"
  }
}
